# macOS
.DS_Store
.AppleDouble
.LSOverride

# Xcode (project file is generated by XcodeGen; do not check in)
WhisperIntent.xcodeproj/
*.xcworkspace/
xcuserdata/
*.xcuserstate
*.xccheckout
*.moved-aside
*.hmap
DerivedData/
build/

# Swift Package Manager
# NOTE: Package.resolved is intentionally NOT ignored. Whisper Intent is an
# application (not a library), so the resolved dependency graph is committed
# to keep builds reproducible across machines and CI.
.build/
.swiftpm/

# Coverage / profiling
*.profraw
*.profdata

# Local spike/runtime logs
logs/

# App build artifacts
*.ipa
*.dSYM.zip
*.dSYM/

# WhisperKit model files (~1.5 GB). These are not source code and must not
# enter git history. They are placed under App/WhisperIntent/Resources/Models/
# at build time by a download script (see docs/spikes/S4-install-size.md).
# A README.md in that directory is committed so the structure is visible.
App/WhisperIntent/Resources/Models/**
!App/WhisperIntent/Resources/Models/README.md
!App/WhisperIntent/Resources/Models/.gitkeep

# Editor
.vscode/
.idea/
*.swp

# CocoaPods / Carthage (not used, but defensive)
Pods/
Carthage/

# Fastlane (if added later)
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# =============================================================================
# Secrets and credentials
# =============================================================================
# If any of these patterns matches a file you legitimately need to commit,
# stop and reconsider: it's almost certainly a secret. Move credentials to
# environment variables or to a secret manager, not into the repo.

# Code signing material (Apple)
*.p12
*.p8
*.cer
*.crt
*.csr
*.pem
*.key
*.mobileprovision
*.provisionprofile
*.keystore
AuthKey_*.p8

# App Store Connect API keys
AppStoreConnect_*.json
asc_api_key*.json

# Fastlane (in case it gets adopted later)
fastlane/.env
fastlane/.env.*
fastlane/Appfile.local
fastlane/Matchfile.local

# Local xcconfig overrides (often used for per-developer secret values)
*.local.xcconfig
Config.local.swift
Secrets.swift

# Generic credential / env files
*.env
.env
.env.*
.envrc
.netrc
secrets/
secrets.json
credentials.json

# Spike sample audio (generated by scripts/generate-spike-samples.sh)
App/WhisperIntent/Resources/Samples/*.wav
!App/WhisperIntent/Resources/Samples/README.md

# S3 spike playback samples (generated by scripts/generate-s3-samples.sh)
s3-samples/

# Build output
build/
