# Whisper Intent — Fastlane environment template.
#
# Copy this file to `fastlane/.env` (gitignored) and fill in real values.
# Never commit `.env` — every variable below is identifying or secret.
#
#   cp fastlane/.env.example fastlane/.env

# -----------------------------------------------------------------------------
# Apple Developer team
# -----------------------------------------------------------------------------

# 10-character alphanumeric team identifier.
# Find it: developer.apple.com → Account → Membership.
DEVELOPMENT_TEAM=XXXXXXXXXX

# Optional — only if you have multiple Apple IDs and want Fastlane to pick
# a specific one. Comment out otherwise.
# FASTLANE_APPLE_ID=mark@example.com

# Optional — if your Apple ID is on more than one App Store Connect team.
# ASC_TEAM_ID=12345678

# -----------------------------------------------------------------------------
# App Store Connect API key
# -----------------------------------------------------------------------------
# Generate at: appstoreconnect.apple.com → Users and Access → Integrations →
# App Store Connect API. Required role: App Manager or Admin.

ASC_KEY_ID=ABCDE12345
ASC_ISSUER_ID=00000000-0000-0000-0000-000000000000

# Absolute path to the downloaded .p8 file. Keep the .p8 outside the repo or
# in a secret manager — never inside it. The .gitignore excludes AuthKey_*.p8
# as a defensive measure if the file accidentally lands in the working tree.
ASC_KEY_FILEPATH=/absolute/path/to/AuthKey_ABCDE12345.p8
